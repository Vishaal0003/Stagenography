{
  "name": "steganography-app",
  "version": "1.0.0",
  "description": "Image Steganography Web Application",
  "private": true,
  "scripts": {
    "install-all": "npm install && cd backend && npm install && cd ../frontend && npm install && cd ..",
    "dev:backend": "cd backend && npm run dev",
    "dev:frontend": "cd frontend && npm run dev",
    "build:backend": "cd backend && npm run build",
    "build:frontend": "cd frontend && npm run build",
    "start:backend": "cd backend && npm start",
    "vercel-build": "npm install && npm run build:backend && npm run build:frontend"
  },
  "dependencies": {
    "formidable": "^3.5.1"
  },
  "devDependencies": {
    "@vercel/node": "^3.0.11"
  },
  "keywords": [
    "steganography",
    "encryption",
    "image",
    "AES-256",
    "LSB"
  ]
}
